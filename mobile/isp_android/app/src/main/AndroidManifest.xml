<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".IspApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="false"
        android:theme="@style/Theme.IspManagement"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.IspManagement">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ui.client.ClientMainActivity" android:exported="false" />
        <activity android:name=".ui.admin.AdminMainActivity" android:exported="false" />
        <activity android:name=".ui.client.ClientPayActivity" android:exported="false" />
        <activity android:name=".ui.client.ClientPackageActivity" android:exported="false" />
        <activity android:name=".ui.client.ClientPasswordActivity" android:exported="false" />
        <activity android:name=".ui.client.ClientTicketActivity" android:exported="false" />
        <activity android:name=".ui.admin.AdminBillReceiveActivity" android:exported="false" />
        <activity android:name=".ui.admin.AdminMonitoringActivity" android:exported="false" />
        <activity android:name=".ui.admin.AdminClientsActivity" android:exported="false" />
        <activity android:name=".ui.admin.AdminClientDetailActivity" android:exported="false" />
        <activity android:name=".ui.admin.AdminExpensesActivity" android:exported="false" />
    </application>
</manifest>
