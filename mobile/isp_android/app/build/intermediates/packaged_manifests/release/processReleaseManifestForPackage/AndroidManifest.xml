<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ispplatform.app"
    android:versionCode="1"
    android:versionName="1.0.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <permission
        android:name="com.ispplatform.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.ispplatform.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="com.ispplatform.app.IspApplication"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:extractNativeLibs="false"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="false"
        android:theme="@style/Theme.IspManagement"
        android:usesCleartextTraffic="false" >
        <activity
            android:name="com.ispplatform.app.ui.auth.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.IspManagement" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.ispplatform.app.ui.client.ClientMainActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.admin.AdminMainActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.client.ClientPayActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.client.ClientPackageActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.client.ClientPasswordActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.client.ClientTicketActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.admin.AdminBillReceiveActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.admin.AdminMonitoringActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.admin.AdminClientsActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.admin.AdminClientDetailActivity"
            android:exported="false" />
        <activity
            android:name="com.ispplatform.app.ui.admin.AdminExpensesActivity"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.ispplatform.app.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>