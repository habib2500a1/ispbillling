APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Dhaka
APP_TIMEZONE_LABEL=BDT

# Fast sync (batch DB, smart MikroTik/OLT) — recommended
SYNC_FAST_MODE=true
BANDWIDTH_POLL_INTERVAL=5
APP_URL=https://bill.flixbd.xyz
PORTAL_ENABLED=true
# Landing page “Mobile app” button (defaults to /downloads/isp-radiant.apk)
# MOBILE_APK_URL=https://bill.flixbd.xyz/downloads/isp-radiant.apk

# Public site + staff panel hostnames
ISP_LANDING_DOMAIN=bill.flixbd.xyz
# Leave empty — staff panel at APP_URL/admin (e.g. bill.flixbd.xyz/admin)
ISP_ADMIN_DOMAIN=
# Cloudflare / reverse proxy
TRUSTED_PROXIES=*
SESSION_DOMAIN=.bill.flixbd.xyz

# Comma-separated proxy IPs (load balancer / CDN). Leave empty in local dev to trust all.
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Comma-separated channels, e.g. single,sentry (requires SENTRY_LARAVEL_DSN)
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sentry (optional — set DSN in production; add "sentry" to LOG_STACK)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_LOG_LEVEL=error

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# bKash tokenized checkout (sandbox): https://developer.bka.sh/
# Super-admins can override the following from Filament: System → Integrations (stored encrypted in DB).
BKASH_ENABLED=false
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_HTTP_TIMEOUT=30

SSLCOMMERZ_ENABLED=false
SSLCOMMERZ_SANDBOX=true
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=

NAGAD_ENABLED=false
NAGAD_SANDBOX=true
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PG_PUBLIC_KEY=
NAGAD_MERCHANT_PRIVATE_KEY=

# PipraPay v3 — https://piprapay.readme.io/reference/overview
PIPRAPAY_ENABLED=false
PIPRAPAY_API_MODE=redirect
PIPRAPAY_API_KEY=
# Panel “Base URL”, e.g. https://pay.flixbd.xyz/api
PIPRAPAY_BASE_URL=https://pay.flixbd.xyz/api
# Must be a DOMAIN (PipraPay rejects bare IPs). Same server as APP_URL:
# PIPRAPAY_PUBLIC_URL=http://isp.flixbd.xyz
# or quick fix: PIPRAPAY_PUBLIC_URL=http://72-18-215-205.sslip.io
PIPRAPAY_PUBLIC_URL=
PIPRAPAY_CURRENCY=BDT
PIPRAPAY_HTTP_TIMEOUT=30

RESELLER_PORTAL_ENABLED=true

# Public bill payment (/pay) — client code + OTP + bKash without portal login
BILL_PAY_OTP_ENABLED=true
BILL_PAY_OTP_TTL_SECONDS=600
BILL_PAY_OTP_DIGITS=6
BILL_PAY_OTP_LOG_ONLY=false
BILL_PAY_ALLOW_PARTIAL=true
BILL_PAY_MIN_AMOUNT=10
BILL_PAY_WALLET_TOPUP=true
BILL_PAY_WALLET_TOPUP_MIN=100
BILL_PAY_LINK_TTL_DAYS=7

# SMS — KhudeBarta (Softifybd) https://portal.khudebarta.com/Softifybd/#/technical-details
NOTIFICATIONS_SMS_ENABLED=false
NOTIFICATIONS_SMS_PROVIDER=khudebarta
NOTIFICATIONS_SMS_API_URL=http://portal.khudebarta.com:3775/sendtext
NOTIFICATIONS_SMS_API_KEY=
NOTIFICATIONS_SMS_SECRET_KEY=
NOTIFICATIONS_SMS_SENDER_ID=
KHUDEBARTA_HASH_FORMULA=apikey_secretkey_callerID_toUser_messageContent
# KHUDEBARTA_HASH_UPPERCASE=false
# KHUDEBARTA_DLR_URL=https://your-domain/webhooks/sms/khudebarta/dlr

# Rocket (DBBL) — customer pays merchant Rocket number + enters TrxID on /rocket/pay
ROCKET_ENABLED=false
ROCKET_MERCHANT_NUMBER=
ROCKET_MERCHANT_NAME=
ROCKET_WEBHOOK_SECRET=
# ROCKET_PAYMENT_INSTRUCTIONS=

# Queue heavy jobs (MikroTik poll) — requires queue:work or Horizon
QUEUE_HEAVY_JOBS_ENABLED=false

# Reseller commission SMS/email
NOTIFICATIONS_RESELLER_COMMISSION=true
NOTIFICATIONS_RESELLER_PAYOUT=true

# Due-date reminders (email + log). Super-admins can override in Filament → System → Integrations.
SMS_REMINDERS_ENABLED=false
SMS_REMINDERS_DAYS=3

# Row-level tenancy: use Filament → System → Tenants. Set users.tenant_id for isp-admin; super-admin may leave null to see all.
# Optional: ISP_TENANT_BASE_DOMAIN=isp.example.com → staff log in at https://{tenant-slug}.isp.example.com/admin
# Super-admins can also set this from Filament → System → Integrations (stored in DB; falls back to this .env value when cleared).
ISP_TENANT_BASE_DOMAIN=

# Network automation (MikroTik / RADIUS / OLT stubs). See config/network.php.
NETWORK_PROVISIONER_DRIVER=null
NETWORK_MIKROTIK_PUSH_ENABLED=true
# When true, saving a customer still pushes /ppp/secret over RouterOS API if tenant has enabled MikroTik servers, even when NETWORK_PROVISIONER_DRIVER is null (RADIUS-only uses API for PPP; RADIUS stubs stay separate).
NETWORK_MIKROTIK_ALWAYS_PUSH_PPP_ON_CUSTOMER_SAVE=true
NETWORK_RADIUS_PUSH_ENABLED=true
NETWORK_AUTO_SUSPEND_ENABLED=true
NETWORK_SERVICE_EXPIRY_ENFORCED=true
# MIKROTIK_API_URL=
# MIKROTIK_API_USER=
# MIKROTIK_API_PASSWORD=

# Bandwidth monitor: MikroTik API + FreeRADIUS radacct merge. See config/bandwidth.php, config/radius.php.
BANDWIDTH_COLLECTION_ENABLED=true
BANDWIDTH_POLL_INTERVAL=5
# FreeRADIUS accounting DB (radacct) — enables dual sync with API on Bandwidth monitor.
RADIUS_ACCOUNTING_ENABLED=false
RADIUS_DB_HOST=127.0.0.1
RADIUS_DB_PORT=3306
RADIUS_DB_DATABASE=radius
RADIUS_DB_USERNAME=radius
RADIUS_DB_PASSWORD=
RADIUS_MERGE_WITH_API=true
RADIUS_INTERIM_INTERVAL=300
RADIUS_MAX_ACTIVE_SESSIONS=10000
# RADIUS user admin UI (radcheck / radusergroup CRUD in Filament → Network → RADIUS users)
RADIUS_ADMIN_ENABLED=false
RADIUS_RADCHECK_TABLE=radcheck
RADIUS_RADREPLY_TABLE=radreply
RADIUS_USERGROUP_TABLE=radusergroup

# WhatsApp two-way bot (Meta webhook → /api/webhooks/whatsapp)
WHATSAPP_BOT_ENABLED=false
WHATSAPP_WEBHOOK_VERIFY_TOKEN=isp-webhook-verify
WHATSAPP_BOT_DEFAULT_DEPARTMENT=billing
WHATSAPP_BOT_SEND_PAY_LINKS=true

# FUP / abuse auto-enforcement (suspend or throttle via RADIUS)
BANDWIDTH_ABUSE_AUTO_ENFORCE=false
BANDWIDTH_ABUSE_SUSPEND_DAILY=false
NETFLOW_ABUSE_EVAL_ENABLED=true
NETFLOW_ABUSE_THRESHOLD_GB=200
NETFLOW_ABUSE_ACTION=alert

# Accounting: auto journal on invoice issue
ACCOUNTING_AUTO_POST_INVOICES=false

# Subscriber ID: automatic on create (0=manual, 1=automatic). Panel: Company setup → Customer ID.
SUBSCRIBER_AUTO_GENERATE_CODE=1
# Format when automatic: prefixed_monthly | numeric | prefix_sequential | secret_as_code
SUBSCRIBER_CODE_FORMAT=prefixed_monthly
SUBSCRIBER_CODE_PREFIX=CUST
SUBSCRIBER_NUMERIC_START=10001
SUBSCRIBER_IMPORT_SET_RADIUS_USERNAME=true
SUBSCRIBER_AUTO_IMPORT_MIKROTIK_SECRETS=false

# MikroTik multi-server panel (Filament → Network → MikroTik). See config/mikrotik.php.
MIKROTIK_POLL_STATUS_ENABLED=true
# Hourly scheduler: isp:mikrotik-fetch-details (stores API snapshot in meta). API-heavy — keep false unless needed.
MIKROTIK_FETCH_DETAILS_POLL_ENABLED=false
# Fleet routers with 300+ PPP over WAN: use 30 / 120 (defaults in config/mikrotik.php)
MIKROTIK_CONNECTION_TIMEOUT=30
MIKROTIK_SOCKET_TIMEOUT=120
MIKROTIK_API_MAX_ATTEMPTS=3
MIKROTIK_RETRY_DELAY_MS=400
MIKROTIK_CIRCUIT_BREAKER_ENABLED=true
MIKROTIK_CIRCUIT_FAILURE_THRESHOLD=3
MIKROTIK_CIRCUIT_OPEN_SECONDS=120

# ONU portal status: isp:sync-onu-status-from-meta copies devices.meta → onu_oper_status / offline_reason.
ONU_META_SYNC_ENABLED=true

# Billing: invoice number prefix (year infix optional). See config/billing.php.
BILLING_INVOICE_PREFIX=INV
BILLING_INVOICE_YEAR_INFIX=true
# SNMP (OLT "Test SNMP" in Filament). Requires PHP ext-snmp on the app server, e.g.:
#   sudo apt install php8.3-snmp && sudo systemctl restart php8.3-fpm
#   php -m | grep -i snmp
# net-snmp / PHP ext-snmp (see https://github.com/net-snmp/net-snmp)
# apt install snmp php8.3-snmp  |  snmpwalk -v2c -c COMMUNITY OLT_IP 1.3.6.1.2.1.1.1.0
SNMP_TIMEOUT_US=2000000
SNMP_RETRIES=1
SNMP_USE_PLAIN_VALUES=true

# Network intelligence: OLT SNMP poll (isp:poll-olt-intelligence) + NetFlow ingest
NETWORK_OLT_SNMP_POLL_ENABLED=true
OPTICAL_MONITORING_ENABLED=true
# ISP Digital style: auto OLT pull + PPP login link on save/view (like ispdigita panel)
OPTICAL_ISP_DIGITAL_AUTO_SYNC=true
OPTICAL_AUTO_SYNC_ON_CUSTOMER_VIEW=true
OPTICAL_AUTO_SYNC_ON_CUSTOMER_SAVE=true
OPTICAL_ISP_DIGITAL_INVENTORY_MAX_AGE=180
OPTICAL_AUTO_SYNC_OLT_ON_MAC_LOOKUP=true
# sync = auto runs without queue:work; redis = needs Horizon/queue worker
OPTICAL_CUSTOMER_SYNC_QUEUE=sync
OPTICAL_MIKROTIK_OPTICAL_BRIDGE=true
OPTICAL_WEBHOOK_SECRET=
OPTICAL_WEBHOOK_AUTO_CREATE=true
# RX bands (dBm): excellent -8 to -15, good to -22, weak to -27, critical below -27
OPTICAL_RX_EXCELLENT_MAX=-8
OPTICAL_RX_EXCELLENT_MIN=-15
OPTICAL_RX_GOOD_MIN=-22
OPTICAL_RX_WEAK_MIN=-27
# Laser high: alert when RX/TX exceeds these (short fibre / strong laser)
OPTICAL_RX_HIGH_WARN_ABOVE=-8
OPTICAL_TX_MIN=0.5
OPTICAL_TX_MAX=5.5
OPTICAL_TX_HIGH_WARN_ABOVE=5.5
OPTICAL_ALERT_ON_HIGH_RX=true
OPTICAL_ALERT_ON_HIGH_TX=true
OPTICAL_AUTO_TICKET=true
NETFLOW_ENABLED=true
NETFLOW_WEBHOOK_SECRET=
NETFLOW_RETENTION_DAYS=7

# Customer portal: optional OTP after password. Manage in Filament → System → Customer portal (isp-admin / isp-manager / super-admin).
PORTAL_OTP_ENABLED=false
PORTAL_OTP_LOG_ONLY=false
PORTAL_OTP_TTL_SECONDS=600
PORTAL_OTP_DIGITS=6

# External ticket ingest (WhatsApp / call-center bridge). POST /api/webhooks/support-ticket-ingest with header X-ISP-Webhook-Secret.
ISP_SUPPORT_WEBHOOK_SECRET=

# Platform backup (admin → System → Backup & restore). Requires pg_dump/pg_restore on server for PostgreSQL.
BACKUP_RETENTION_DAYS=14
BACKUP_MAX_ARCHIVES=20
BACKUP_INCLUDE_STORAGE_APP=true
